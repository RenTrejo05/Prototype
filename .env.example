# ========== Next.js (frontend) ==========
# MongoDB solo para auth y usuarios (lib/db.ts).
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# URLs de los servicios desplegados (para que el frontend los llame).
# En local: Inventory API en :4000, Alerts Service en :4001.
NEXT_PUBLIC_INVENTORY_API_URL=http://localhost:4000
NEXT_PUBLIC_ALERTS_API_URL=http://localhost:4001

# ========== Inventory API (services/inventory-api) ==========
# Misma URI de MongoDB; crea colecciones "products" y "sales" en "legacyapp".
# UPSTASH: https://console.upstash.com/ → Redis → REST API.
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...
# PORT=4000

# ========== Alerts Service (services/alerts-service) ==========
# Mismo Redis que Inventory API (misma cola).
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
# PORT=4001
